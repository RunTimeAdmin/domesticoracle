# ── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS (frontend origin) ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3100

# ── Home Assistant (leave blank to use the built-in mock home) ───────────────
ORA_HA_URL=http://homeassistant.local:8123
ORA_HA_TOKEN=

# ── Owner auth token ─────────────────────────────────────────────────────────
# Generated on first run and printed to the log. Copy it here to pin it.
# Set NEXT_PUBLIC_ORA_OWNER_TOKEN in frontend/.env.local to the same value.
ORA_OWNER_TOKEN=

# ── DeerFlow paths (defaults work for local dev) ─────────────────────────────
# DEER_FLOW_PROJECT_ROOT=D:\EchoBond\backend
# DEER_FLOW_CONFIG_PATH=D:\EchoBond\backend\config.yaml

# ── Policy enforcement mode: enforced | audit_only | permissive ───────────────
# Leave blank to use the default (enforced).
# ORA_POLICY_MODE=enforced
