# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional fallback model (DeepSeek-V3) ─────────────────────────────────────
# Note: queries sent to DeepSeek's servers — privacy consideration for home use.
DEEPSEEK_API_KEY=

# ── Owner token ───────────────────────────────────────────────────────────────
# Generated by docker/setup.ps1 (Windows) or docker/setup.sh (Linux/Mac).
# Baked into the frontend bundle at build time — change requires: docker compose up --build
# WARNING: Visible in the JS bundle. Localhost/home-LAN use only.
# See roadmap item #1 (session auth) for a proper solution.
ORA_OWNER_TOKEN=

# ── Backend URL (as seen from the browser, not from inside Docker) ─────────────
ORA_API_URL=http://localhost:8000

# ── Optional: Home Assistant integration ──────────────────────────────────────
ORA_HA_URL=http://homeassistant.local:8123
ORA_HA_TOKEN=

# ── Optional: CORS (comma-separated origins) ──────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3100

# ── Blast-radius limits ────────────────────────────────────────────────────────
# Set to 0 to disable a limit.
ORA_ACTOR_HOURLY_LIMIT=20   # max guarded actions per actor per hour (forced HOLD if exceeded)
ORA_DAILY_CAP=100           # max guarded actions across all actors per day (UTC)

# ── MCP server ─────────────────────────────────────────────────────────────────
# Set ORA_MCP_ENABLED=false to disable the MCP SSE server entirely.
ORA_MCP_ENABLED=true
# If set, every MCP connection must supply this token in the
# X-Ora-Mcp-Token header or ?token= query param.
# Leave blank to rely on network-level auth (nginx, VPN, etc.).
ORA_MCP_TOKEN=
